# ─── Обязательные ключи ───────────────────────────────────────────────────────
# Получить: https://aistudio.google.com → Get API key
GEMINI_API_KEY=your_gemini_api_key_here

# Получить: https://huggingface.co/settings/tokens → New token (read)
HF_API_KEY=your_huggingface_token_here

# ─── Опциональные ─────────────────────────────────────────────────────────────
# Пароль для входа (по умолчанию: reelforge2024)
ADMIN_PASSWORD=reelforge2024

# Базовый URL (нужен для production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Для Vercel free лучше отключить серверный рендер MP4 (иначе возможны таймауты)
ENABLE_SERVER_RENDER=true

# Токен для внутренних запросов pipeline -> /api/render
INTERNAL_API_TOKEN=change_me_internal_token

# Внешний рендер (когда ENABLE_SERVER_RENDER=false)
EXTERNAL_RENDER_WEBHOOK_URL=
EXTERNAL_RENDER_WEBHOOK_TOKEN=
RENDER_CALLBACK_SECRET=change_me_callback_secret
